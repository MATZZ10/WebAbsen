# Database
DATABASE_URL=postgresql://user:password@localhost:5432/webabsen

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Teacher Emails (comma-separated)
TEACHER_EMAILS=teacher1@school.com,teacher2@school.com

# ============================================
# GEOLOCATION CONFIGURATION
# ============================================
# Mode BARU: School Settings Management
# 
# GEOLOCATION_MODE DEPRECATED - Sudah diganti dengan database school_settings
# Sekarang guru bisa mengatur lokasi sekolah dan radius absensi langsung di:
# http://localhost:3000/admin/settings
#
# Fitur yang tersedia:
# ✓ Atur nama sekolah
# ✓ Atur koordinat lokasi (latitude, longitude)
# ✓ Atur radius lokasi (dalam meter)
# ✓ Buka/Tutup sistem absensi
# ✓ Atur jam mulai dan jam akhir absensi
# ✓ Izinkan/Tolak absensi terlambat
#
# Database otomatis membuat default settings jika kosong:
# - Nama: Sekolah
# - Latitude: -6.2088 (Jakarta Selatan)
# - Longitude: 106.8456
# - Radius: 1000 meter
# - Start Time: 07:00
# - End Time: 14:00
#
# Tidak perlu set variabel geolocation lagi!
# Semua manage langsung dari admin panel.
#

